{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Server",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/backend/cmd/server/main.go",
            "cwd": "${workspaceFolder}",
            "env": {
                "PORT": "8080"
            },
            "dlvFlags": ["--check-go-version=false"],
            "showLog": true,
            "trace": "verbose"
        },
        {
            "name": "Debug Server (Alternative Port)",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/backend/cmd/server/main.go",
            "cwd": "${workspaceFolder}",
            "env": {
                "PORT": "8081"
            },
            "dlvFlags": ["--check-go-version=false"],
            "showLog": true
        },
         {
            "name": "Launch TheCampaign console",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/backend/cmd/main.go",
            "cwd": "${workspaceFolder}/backend",
            "dlvFlags": ["--check-go-version=false"]
        }
    ]
}